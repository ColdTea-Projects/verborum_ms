{
  "realm": "verborum",
  "enabled": true,
  "displayName": "Verborum",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "verifyEmail": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 5184000,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard Verborum user. Every registered account gets this."
      },
      {
        "name": "admin",
        "description": "Verborum administrator."
      }
    ]
  },
  "clients": [
    {
      "clientId": "verborum-app",
      "name": "Verborum mobile (Android + iOS)",
      "description": "Public client, Authorization Code + PKCE. Integration doc 6.1.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "de.coldtea.verborum://oauth2redirect/*",
        "http://localhost:*"
      ],
      "webOrigins": [
        "+"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "300"
      }
    },
    {
      "clientId": "verborum-web",
      "name": "Verborum web",
      "description": "Public client, Authorization Code + PKCE. May be replaced by a BFF confidential client - Integration doc 6.3 is undecided.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "300"
      }
    },
    {
      "clientId": "verborum-backend",
      "name": "Verborum backend (service-to-service)",
      "description": "Confidential client. Used by ms_user for Keycloak Admin API calls during registration.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "implicitFlowEnabled": false,
      "secret": "local-dev-only-change-me",
      "attributes": {
        "access.token.lifespan": "300"
      }
    },
    {
      "clientId": "verborum-dev-cli",
      "name": "LOCAL DEV ONLY - password grant for testing",
      "description": "Direct Access Grants so a developer can obtain a user token with curl. NOT part of the auth contract and MUST NOT exist in any shared or production realm - the real clients use Authorization Code + PKCE only.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "email": "testuser@example.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testuser",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "testadmin",
      "enabled": true,
      "emailVerified": true,
      "email": "testadmin@example.com",
      "firstName": "Test",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "testadmin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "admin"
      ]
    }
  ]
}
